{
    "name": "@geoadmin/tooltip",
    "version": "0.0.1",
    "description": "Tooltip for geoadmin",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.umd.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "dev": "vite",
        "type-check": "vue-tsc --build",
        "generate-types": "vue-tsc --declaration",
        "build": "pnpm run type-check && pnpm run generate-types && vite build",
        "preview": "vite preview",
        "test:unit": "vitest --run --mode development --environment jsdom",
        "test:unit:watch": "vitest --mode development --environment jsdom"
    },
    "dependencies": {
        "@floating-ui/vue": "catalog:",
        "vue": "catalog:"
    },
    "devDependencies": {
        "@intlify/core-base": "catalog:",
        "@tailwindcss/vite": "catalog:",
        "@tsconfig/node22": "catalog:",
        "@types/jsdom": "catalog:",
        "@vitejs/plugin-vue": "catalog:",
        "@vue/tsconfig": "catalog:",
        "tailwindcss": "catalog:",
        "vite": "catalog:",
        "vite-plugin-vue-devtools": "catalog:",
        "vitest": "catalog:",
        "vue-tsc": "catalog:"
    }
}
